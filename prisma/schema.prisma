generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==================== Auth.js Models ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ==================== Store Models ====================

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive, sortOrder])
}

model Product {
  id               String         @id @default(cuid())
  sku              String         @unique
  name             String
  slug             String         @unique
  shortDescription String?
  description      String?        @db.Text
  price            Int            // kopiyky (cents)
  compareAtPrice   Int?           // original price if discounted
  stockStatus      String         @default("in_stock") // in_stock, out_of_stock, preorder
  quantity         Int?
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  metaTitle        String?
  metaDesc         String?
  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id])
  images           ProductImage[]
  orderItems       OrderItem[]
  reviews          ProductReview[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([isActive, sortOrder])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model OrderCounter {
  id    String @id @default("singleton")
  value Int    @default(5000)
}

model Order {
  id                 String       @id @default(cuid())
  orderNumber        String       @unique
  publicOrderNumber  String?      @unique // K-5001, K-5002, ...
  status             String       @default("new")
  customerName       String
  customerPhone      String
  customerEmail      String?
  deliveryMethod     String
  deliveryCity       String?
  deliveryAddress    String?
  deliveryBranchRef  String?
  deliveryBranchName String?
  comment            String?
  subtotal           Int
  discountTotal      Int          @default(0)
  deliveryCost       Int          @default(0)
  total              Int
  currency           String       @default("UAH")
  paymentMethod      String
  paymentStatus      String       @default("pending")
  paymentProvider    String?
  paymentPurpose     String?      // full_payment, cod_prepayment
  prepaymentAmount   Int?         // in kopiyky, e.g. 20000 = 200 UAH
  externalPaymentId  String?
  keycrmOrderId      String?
  keycrmBuyerId      String?
  keycrmPaymentId    String?
  keycrmSyncStatus   String       @default("pending") // pending, synced, failed, not_required
  keycrmSyncError    String?
  keycrmSyncRetries  Int          @default(0)
  idempotencyKey     String       @unique
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  utmTerm            String?
  utmContent         String?
  source             String       @default("website")
  emailSentAt        DateTime?
  smsSentAt          DateTime?
  accessTokenHash    String?      @unique
  accessTokenExpiresAt DateTime?
  customerId         String?
  userId             String?
  customer           Customer?    @relation(fields: [customerId], references: [id])
  trackingNumber     String?
  deliveryStatus     String?
  keycrmStatusId     Int?
  keycrmStatusName   String?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  items              OrderItem[]
  payments           PaymentEvent[]
  statusHistory      OrderStatusHistory[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([orderNumber])
  @@index([keycrmSyncStatus])
  @@index([paymentStatus])
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([customerPhone])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  sku       String
  price     Int
  quantity  Int
  lineTotal Int
  imageUrl  String?

  @@index([orderId])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider        String
  eventType       String   // created, success, failure, refund
  externalId      String?
  amount          Int
  currency        String   @default("UAH")
  rawPayload      String?  @db.Text
  signatureValid  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([externalId])
}

model IntegrationLog {
  id            String   @id @default(cuid())
  requestId     String   @unique @default(cuid())
  integration   String   // keycrm, wayforpay, novaposhta
  direction     String   // outbound, inbound
  method        String
  endpoint      String
  entityType    String?
  entityId      String?
  payloadHash   String?
  requestBody   String?  @db.Text
  responseBody  String?  @db.Text
  responseStatus Int?
  errorMessage  String?
  retryCount    Int      @default(0)
  durationMs    Int?
  isResolved    Boolean  @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([integration, createdAt])
  @@index([entityType, entityId])
}

model Page {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String   @db.Text
  isActive        Boolean  @default(true)
  showInNav       Boolean  @default(true)
  showInFooter    Boolean  @default(true)
  showInMobileMenu Boolean @default(true)
  displayOnHome   Boolean  @default(false)
  isSystem        Boolean  @default(false)
  metaTitle     String?
  metaDesc      String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?
  content         String    @db.Text
  coverImageUrl   String?
  publishedAt     DateTime?
  isPublished     Boolean   @default(false)
  seoTitle        String?
  seoDescription  String?
  ctaLabel        String?
  ctaUrl          String?
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  mobileImageUrl String?
  linkUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Redirect {
  id          String   @id @default(cuid())
  fromPath    String   @unique
  toPath      String
  statusCode  Int      @default(301)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SyncJob {
  id           String   @id @default(cuid())
  entityType   String   // order
  entityId     String
  action       String   // create_order, attach_payment, create_buyer
  status       String   @default("pending") // pending, processing, completed, failed
  attempts     Int      @default(0)
  maxAttempts  Int      @default(5)
  lastError    String?
  nextRetryAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, nextRetryAt])
  @@index([entityType, entityId])
}

model PaymentMethod {
  id                    String   @id @default(cuid())
  key                   String   @unique // card_wayforpay, cod_cash_on_delivery
  title                 String   // "Оплата карткою онлайн"
  description           String?  // Short description for checkout
  customerInstruction   String?  @db.Text // Template shown on success page
  checkoutButtonLabel   String?  // Button text in checkout, e.g. "Підтвердити та оплатити"
  enabled               Boolean  @default(true)
  requiresOnlinePayment Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Customer {
  id              String   @id @default(cuid())
  phoneNormalized String   @unique
  email           String?
  name            String?
  orders          Order[]
  sessions        CustomerSession[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CustomerSession {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@index([tokenHash])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  source    String   // local, keycrm, payment, system
  oldStatus String?
  newStatus String
  message   String?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model ProductReview {
  id           String    @id @default(cuid())
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName String
  customerEmail String?
  rating       Int       // 1-5
  text         String    @db.Text
  status       String    @default("pending") // pending, approved, rejected
  source       String    @default("customer") // customer, admin
  displayDate  DateTime?  // admin-controlled display date; fallback to createdAt
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([productId, status])
  @@index([status])
}
